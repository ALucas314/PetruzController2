# ========== RODAR O PROJETO LOCALMENTE ==========
# Dois arquivos (não commitar nenhum dos dois):
#
# 1) .env na RAIZ → Vite (frontend)
#    cp .env.example .env
#
# 2) src/Data/.env → servidor Node (server/npm run dev)
#    Copie o bloco "Backend" abaixo para src/Data/.env e preencha.
#
# Supabase: Dashboard → Project Settings → API
# NUNCA commite .env com chaves reais.

# ---- Frontend (raiz: .env) ----
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_API_URL=http://localhost:3001
VITE_APP_URL=http://localhost:8080

# ---- Backend (arquivo: src/Data/.env) ----
# SUPABASE_URL=https://seu-projeto.supabase.co
# SUPABASE_ANON_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=...
# PORT=3001
# JWT_SECRET=uma-string-longa-secreta
