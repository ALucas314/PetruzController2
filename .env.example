# ========== RODAR O PROJETO LOCALMENTE ==========
# 1. Copie este arquivo para .env na RAIZ do projeto (mesma pasta do package.json):
#    cp .env.example .env
# 2. Preencha as variáveis abaixo (Supabase: Dashboard > Project Settings > API)
# 3. Rode: npm run dev
# NUNCA commite o arquivo .env

# ---- Frontend (obrigatório para login e dados) ----
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Opcional: link do app (Esqueci senha)
# VITE_APP_URL=http://localhost:8080

# ---- Backend (só se for usar o servidor Node em server/) ----
# SUPABASE_URL=
# SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SECRET_KEY=
# PORT=3001
